# ─── FastAPI Backend ───────────────────────────────
DATABASE_URL=sqlite:///./syncpad.db
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Optional: Set for real AI features (works without it using demo mode)
OPENAI_API_KEY=

# ─── PostgreSQL (via Docker) ──────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=syncpad

# ─── Redis (for Hocuspocus horizontal scaling) ────
REDIS_URL=redis://localhost:6379
